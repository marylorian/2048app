{
  "name": "react-native-2048",
  "version": "1.0.0",
  "private": true,
  "main": "main.ts",
  "scripts": {
    "prepare": "husky",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build:web",
    "build:web": "expo export --platform web --output-dir dist",
    "build:android": "npx eas-cli build --platform android --profile production",
    "build:android:apk": "npx eas-cli build --platform android --profile preview",
    "build:ios": "npx eas-cli build --platform ios --profile production",
    "build:ios:simulator": "npx eas-cli build --platform ios --profile simulator",
    "build:native": "npx eas-cli build --platform all --profile production"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@expo/vector-icons": "~14.0.4",
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo": "~52.0.0",
    "expo-font": "~13.0.4",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-safe-area-context": "4.12.0",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.8.0",
    "@types/react": "^18.3.28",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.0",
    "prettier": "^3.8.3",
    "react-test-renderer": "^18.3.1",
    "typescript": "^6.0.3"
  }
}
